rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ ADMIN HELPER ============
    // Checks user_roles/{uid}.roles array for 'admin' — no custom claim required.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // ============ PINCODES ============
    // Public read - anyone can check delivery availability
    // No write allowed from client (only Admin SDK can write)
    match /pincodes/{pincodeId} {
      allow read: if true;
      allow write: if false;
    }

    // ============ PRODUCTS ============
    // Public read for browsing, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
      
      // Product ratings subcollection
      // Public read for approved ratings, authenticated users can create with validation
      match /product_ratings/{ratingId} {
        allow read: if true; // Public can read approved ratings
        // Strict validation for creating ratings
        allow create: if request.auth != null && 
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.rating >= 1 &&
                         request.resource.data.rating <= 5;
        allow update, delete: if request.auth != null && isAdmin();
      }
      
      // Lab reports subcollection
      // Public read, only admin can write
      match /lab_reports/{reportId} {
        allow read: if true; // Public can view lab reports for products
        allow write: if request.auth != null && isAdmin();
      }

      // Product FAQs subcollection
      // Public read, only admin can write
      match /product_faqs/{faqId} {
        allow read: if true; // Public can read FAQs
        allow write: if request.auth != null && isAdmin();
      }
    }

    // ============ BLOGS ============
    // Public read, only admin can write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ============ PAYMENT TRANSACTIONS ============
    // GUESTS and authenticated users can create payment transactions for checkout.
    // Only authenticated users and admins can read their own transactions.
    // Transactions are immutable once created (updated server-side only).
    match /payment_transactions/{txId} {
      allow read: if isAdmin() || 
                    (request.auth != null && resource.data.user_id == request.auth.uid);
      allow create: if true;  // Anyone (guests or authenticated) can create transactions
      allow update: if false; // only updated server-side via Admin SDK
      allow delete: if false;
    }

    // ============ ORDERS ============
    // Anyone (guests, users, admins) can read orders for tracking purposes
    // Anyone can create orders with strict validation (for checkout)
    // Only admins can update/delete orders
    match /orders/{orderId} {
      // Read: ANYONE can read orders for tracking (via order ID, email, or phone)
      // This is a public feature - customers should be able to track their orders
      allow read: if true;
      
      // Create: ANYONE (guests or authenticated) can create orders with strict validation
      allow create: if 
        // Must have required fields
        request.resource.data.keys().hasAll(['items', 'total_amount', 'customer_email', 'customer_phone', 'status']) &&
        // Items must be a non-empty array
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.items.size() <= 50 &&  // Max 50 items per order
        // Total must be positive
        request.resource.data.total_amount >= 0 &&
        request.resource.data.total_amount <= 1000000 &&  // Max ₹10 lakh per order
        // Email must be valid format
        request.resource.data.customer_email.matches('.*@.*\\..*') &&
        // Phone must be 10 digits
        request.resource.data.customer_phone.matches('[0-9]{10}') &&
        // Status can be: 'pending' (online payment), 'confirmed' (COD), or 'payment_initiated'
        request.resource.data.status in ['pending', 'confirmed', 'payment_initiated'];
      
      // Update: Admins can update all orders. 
      // Authenticated users can claim guest orders (link to their account)
      allow update: if isAdmin() ||
                      (request.auth != null &&
                       // Order must be a guest order (no user_id yet)
                       resource.data.user_id == null &&
                       // Email must match authenticated user
                       resource.data.customer_email.lower() == request.auth.token.email.lower() &&
                       // Only allowing user_id to be set to the current user
                       request.resource.data.user_id == request.auth.uid &&
                       // No other fields should be modified during linking
                       request.resource.data.keys() == resource.data.keys().concat(['user_id']) ||
                       request.resource.data.keys() == resource.data.keys());
      
      // Delete: Only admins can delete orders
      allow delete: if isAdmin();
    }

    // ============ USER PROFILES ============
    // Users can read/write their own profile
    // Admins can read all profiles
    match /profiles/{userId} {
      allow read: if request.auth != null && 
                    (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============ USERS COLLECTION ============
    // Users can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && 
                    (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============ PROMO CODES ============
    // Public read for applying promo codes
    // Only admin can write
    match /promo_codes/{promoId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ============ NEWSLETTER SUBSCRIBERS ============
    // Anyone can subscribe (create), only admin can read all
    match /newsletter_subscribers/{subId} {
      allow create: if true;
      allow read: if request.auth != null && isAdmin();
      allow update, delete: if false;
    }

    // ============ PRODUCT FAQs ============
    // Public read, only admin can write
    match /product_faqs/{faqId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ============ SAVED ADDRESSES ============
    // Users can manage their own saved addresses
    match /saved_addresses/{addressId} {
      allow read: if request.auth != null && 
                    resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
                               resource.data.user_id == request.auth.uid;
    }

    // ============ USER ROLES ============
    // Only the owning user or an admin can read roles.
    // Only server-side (Admin SDK) can write — clients cannot self-assign admin.
    match /user_roles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // write only via Admin SDK
    }

    // ============ FAVORITES ============
    // Users can manage their own favorites (save/read products they like)
    match /favorites/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============ KNOW YOUR FOOD LINKS ============
    // Public read for displaying links on the KYF page
    // Only admins can write
    match /kyf_links/{linkId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // ============ KNOW YOUR FOOD - PAGE CONTENT ============
    // Public read so the KYF page can fetch admin overrides
    // Only admins can write
    match /kyf_items/{itemId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // ============ KNOW YOUR FOOD - INS DEFINITIONS ============
    // Public read so the KYF page can display custom definitions
    // Only admins can write
    match /ins_definitions/{number} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
