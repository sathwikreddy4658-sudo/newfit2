rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ PINCODES ============
    // Public read - anyone can check delivery availability
    // No write allowed from client (only Admin SDK can write)
    match /pincodes/{pincodeId} {
      allow read: if true;
      allow write: if false;
    }

    // ============ PRODUCTS ============
    // Public read for browsing, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ============ BLOGS ============
    // Public read, only admin can write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ============ PAYMENT TRANSACTIONS ============
    // Authenticated users can read their own payment transactions
    // Anyone can create (guest checkout support)
    match /payment_transactions/{txId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if false; // only updated server-side via Admin SDK
      allow delete: if false;
    }

    // ============ ORDERS ============
    // Authenticated users can read their own orders, admins can read/write all.
    // Guest checkout is supported — order creation is allowed without auth.
    match /orders/{orderId} {
      allow read: if request.auth != null && 
                    (resource.data.user_id == request.auth.uid || 
                     request.auth.token.admin == true);
      allow create: if true;  // guests and logged-in users can both place orders
      allow update: if request.auth != null && request.auth.token.admin == true;
      allow delete: if false;
    }

    // ============ USER PROFILES ============
    // Users can read/write their own profile
    // Admins can read all profiles
    match /profiles/{userId} {
      allow read: if request.auth != null && 
                    (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============ USERS COLLECTION ============
    // Users can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && 
                    (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============ PROMO CODES ============
    // Public read for applying promo codes
    // Only admin can write
    match /promo_codes/{promoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ============ NEWSLETTER SUBSCRIBERS ============
    // Anyone can subscribe (create), only admin can read all
    match /newsletter_subscribers/{subId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow update, delete: if false;
    }

    // ============ PRODUCT FAQs ============
    // Public read, only admin can write
    match /product_faqs/{faqId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ============ LAB REPORTS ============
    // Only authenticated users can read their own lab reports
    match /lab_reports/{reportId} {
      allow read: if request.auth != null && 
                    (resource.data.userId == request.auth.uid || 
                     request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ============ SAVED ADDRESSES ============
    // Users can manage their own saved addresses
    match /saved_addresses/{addressId} {
      allow read: if request.auth != null && 
                    resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
                               resource.data.user_id == request.auth.uid;
    }

    // ============ USER ROLES ============
    // Only the owning user or an admin can read roles.
    // Only server-side (Admin SDK) can write — clients cannot self-assign admin.
    match /user_roles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // write only via Admin SDK
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
