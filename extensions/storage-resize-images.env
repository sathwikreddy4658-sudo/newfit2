CACHE_CONTROL_HEADER=max-age=86400
CONTENT_FILTER_LEVEL=OFF
DELETE_ORIGINAL_FILE=false
FAILED_IMAGES_PATH=failed-resizes
firebaseextensions.v1beta.function/location=us-east4
FUNCTION_MEMORY=1024
IMAGE_TYPE=jpeg,png
IMG_BUCKET=newfit-35320.firebasestorage.app
IMG_SIZES=200x200,500x500,800x800
INCLUDE_PATH_LIST=/products,/blogs,/lab-reports,/assets
IS_ANIMATED=true
MAKE_PUBLIC=true
OUTPUT_OPTIONS={"jpeg": 85, "png": 85}
REGENERATE_TOKEN=false
RESIZED_IMAGES_PATH=thumbs